# Set default behavior to automatically normalize line endings
* text=auto

# Force Kotlin/Java/XML/Gradle files to use LF in the repo
*.kt text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.pro text eol=lf

# Ignore CRLF warnings for images, binaries, etc
*.png binary
*.jpg binary
*.ico binary
*.jar binary
